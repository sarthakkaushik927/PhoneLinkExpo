# ============================================================
# Linux Phone Link — Server Environment Configuration
# ============================================================
# Copy this file to .env and adjust values as needed.
# The server reads these variables at startup via python-dotenv.
# ============================================================

# Network
HOST=0.0.0.0       # Bind to all LAN interfaces
PORT=8765          # Must match SERVER_PORT in mobile-app/src/config/server.config.js

# Behaviour
ACCEPT_DELAY=3     # Seconds to wait before auto-accepting a call (simulated reaction time)

# Logging
LOG_LEVEL=INFO     # Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
